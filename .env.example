# ─── Login Google ─────────────────────────────────────────────────────────────
# Email padrão: stephanie.silva@alicerceedu.com.br (sobrescreva se quiser outro)
# GIP_EMAIL=stephanie.silva@alicerceedu.com.br
GIP_PASSWORD=
# Para usar SOMENTE login manual (abre o botão; você digita no Google), defina:
# GIP_MANUAL_GOOGLE_LOGIN=1

# ─── Sessão (opcional, evita re-login) ────────────────────────────────────────
# Caminho do storage state salvo previamente (carrega ao iniciar):
# GIP_STORAGE_STATE=.auth/gip.json
# Caminho onde salvar a sessão após login bem-sucedido:
# GIP_SAVE_STORAGE_STATE=.auth/gip.json

# ─── Navegador ────────────────────────────────────────────────────────────────
# chrome (padrão, instalado no sistema) ou chromium (browser empacotado)
# GIP_BROWSER=chromium
# Argumentos extras do Chrome (separados por espaço)
# GIP_CHROME_ARGS=--disable-crash-reporter --disable-breakpad

# ─── Turma ────────────────────────────────────────────────────────────────────
# Código digitado no campo "Buscar turma" (default: 1558)
# GIP_TURMA_CODIGO=1558
# Regex para identificar o item da turma na lista (default: CO-<codigo>.*Instituto Eurofarma)
# GIP_TURMA_REGEX=CO-1558.*Instituto Eurofarma

# ─── Retry da busca ───────────────────────────────────────────────────────────
# Total de tentativas (1ª + reloads). Default: 4
# GIP_TURMA_MAX_TENTATIVAS=4
# Espera (ms) antes de digitar o código em CADA tentativa. Default: 4000
# GIP_TURMA_ESPERA_MS=4000
